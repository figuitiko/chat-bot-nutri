generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BotRuleMatchType {
  EXACT
  KEYWORD
  CONTAINS
  FALLBACK
}

enum TemplateChannel {
  WHATSAPP
}

enum TemplateKind {
  TEXT
  TWILIO_CONTENT_TEMPLATE
}

enum TemplateDeliveryMode {
  STANDARD
  MEDIA_FIRST
}

enum CourseStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CourseStepType {
  CONTENT
  QUESTION
  RESULT
  HANDOFF
  SYSTEM
}

enum AssetKind {
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  OTHER
}

enum ConversationStatus {
  OPEN
  CLOSED
  ESCALATED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageChannel {
  WHATSAPP
}

enum MessageProvider {
  TWILIO
}

enum MessageType {
  TEXT
  TEMPLATE
  SYSTEM
}

enum MessageStatus {
  RECEIVED
  QUEUED
  SENT
  DELIVERED
  FAILED
  READ
}

enum WebhookSource {
  TWILIO_INBOUND
  TWILIO_STATUS
}

enum FlowStepInputType {
  CHOICE
  FREE_TEXT
}

enum FlowStepRenderMode {
  TEXT
  AUTO
  QUICK_REPLY
  LIST_PICKER
}

model Contact {
  id             String         @id @default(cuid())
  phone          String         @unique
  waId           String?
  name           String?
  profileName    String?
  locale         String         @default("es-MX")
  isOptedIn      Boolean        @default(true)
  lastInboundAt  DateTime?
  lastOutboundAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  accessCredential ContactAccessCredential?
  conversations  Conversation[]
  enrollments    CourseEnrollment[]
  messages       Message[]
}

model ContactAccessCredential {
  id             String   @id @default(cuid())
  contactId      String   @unique
  secretHash     String
  isActive       Boolean  @default(true)
  failedAttempts Int      @default(0)
  lockedUntil    DateTime?
  lastVerifiedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  contact        Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Asset {
  id          String        @id @default(cuid())
  kind        AssetKind
  url         String        @unique
  pathname    String
  contentType String?
  sizeBytes   Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  courses     Course[]      @relation("CourseCoverAsset")
  modules     CourseModule[] @relation("ModuleIntroAsset")
  steps       CourseStep[]  @relation("StepMediaAsset")
}

model Course {
  id              String         @id @default(cuid())
  slug            String         @unique
  name            String
  description     String?
  status          CourseStatus   @default(DRAFT)
  isActive        Boolean        @default(false)
  activatedAt     DateTime?
  archivedAt      DateTime?
  coverAssetId    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  coverAsset      Asset?         @relation("CourseCoverAsset", fields: [coverAssetId], references: [id], onDelete: SetNull)
  enrollments     CourseEnrollment[]
  modules         CourseModule[]
  conversations   Conversation[]
  selectedInConversations Conversation[] @relation("ConversationSelectedCourse")

  @@index([status, isActive])
}

model CourseEnrollment {
  id          String   @id @default(cuid())
  contactId   String
  courseId    String
  isActive    Boolean  @default(true)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([contactId, courseId])
  @@index([contactId, isActive])
  @@index([courseId, isActive])
}

model CourseModule {
  id             String         @id @default(cuid())
  courseId       String
  slug           String
  title          String
  summary        String?
  sortOrder      Int
  introAssetId   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  course         Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  introAsset     Asset?         @relation("ModuleIntroAsset", fields: [introAssetId], references: [id], onDelete: SetNull)
  steps          CourseStep[]
  conversations  Conversation[]

  @@unique([courseId, slug])
  @@index([courseId, sortOrder])
}

model CourseStep {
  id                  String               @id @default(cuid())
  moduleId            String
  slug                String
  title               String
  stepType            CourseStepType       @default(CONTENT)
  sortOrder           Int
  body                String
  kind                TemplateKind         @default(TEXT)
  deliveryMode        TemplateDeliveryMode @default(STANDARD)
  renderMode          FlowStepRenderMode   @default(TEXT)
  inputType           FlowStepInputType    @default(CHOICE)
  mediaAssetId        String?
  mediaUrl            String?
  captureKey          String?
  assessmentKey       String?
  correctAnswer       String?
  scoreWeight         Int?
  isAssessmentResult  Boolean              @default(false)
  isTerminal          Boolean              @default(false)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  module              CourseModule         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  mediaAsset          Asset?               @relation("StepMediaAsset", fields: [mediaAssetId], references: [id], onDelete: SetNull)
  transitions         CourseTransition[]   @relation("CourseTransitionSource")
  incomingTransitions CourseTransition[]   @relation("CourseTransitionTarget")
  conversations       Conversation[]       @relation("ConversationCurrentCourseStep")

  @@unique([moduleId, slug])
  @@index([moduleId, sortOrder])
}

model CourseTransition {
  id           String           @id @default(cuid())
  stepId        String
  nextStepId    String?
  matchType     BotRuleMatchType
  pattern       String
  displayLabel  String?
  displayHint   String?
  outputValue   String?
  priority      Int             @default(100)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  step          CourseStep      @relation("CourseTransitionSource", fields: [stepId], references: [id], onDelete: Cascade)
  nextStep      CourseStep?     @relation("CourseTransitionTarget", fields: [nextStepId], references: [id], onDelete: SetNull)

  @@index([stepId, priority])
}

model AdminUser {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BotFlow {
  id                  String         @id @default(cuid())
  key                 String         @unique
  name                String
  description         String?
  isActive            Boolean        @default(true)
  entryStepKey        String?
  fallbackTemplateKey String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  conversations       Conversation[]
  rules               BotRule[]
  steps               BotFlowStep[]
}

model BotRule {
  id                  String           @id @default(cuid())
  flowId              String
  matchType           BotRuleMatchType
  pattern             String
  responseTemplateKey String?
  targetFlowKey       String?
  priority            Int              @default(100)
  isActive            Boolean          @default(true)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  flow                BotFlow          @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId, priority])
}

model BotFlowStep {
  id                  String                          @id @default(cuid())
  flowId              String
  key                 String
  name                String
  templateKey         String
  inputType           FlowStepInputType              @default(CHOICE)
  renderMode          FlowStepRenderMode             @default(TEXT)
  assessmentKey       String?
  correctAnswer       String?
  scoreWeight         Int?
  isAssessmentResult  Boolean                        @default(false)
  captureKey          String?
  isTerminal          Boolean                         @default(false)
  isActive            Boolean                         @default(true)
  createdAt           DateTime                        @default(now())
  updatedAt           DateTime                        @updatedAt
  flow                BotFlow                         @relation(fields: [flowId], references: [id], onDelete: Cascade)
  transitions         BotFlowTransition[]             @relation("TransitionSource")
  incomingTransitions BotFlowTransition[]             @relation("TransitionTarget")
  conversations       Conversation[]                  @relation("ConversationCurrentStep")

  @@unique([flowId, key])
  @@index([flowId])
}

model BotFlowTransition {
  id          String           @id @default(cuid())
  stepId       String
  nextStepId   String?
  matchType    BotRuleMatchType
  pattern      String
  outputValue  String?
  priority     Int              @default(100)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  step         BotFlowStep      @relation("TransitionSource", fields: [stepId], references: [id], onDelete: Cascade)
  nextStep     BotFlowStep?     @relation("TransitionTarget", fields: [nextStepId], references: [id], onDelete: SetNull)

  @@index([stepId, priority])
}

model MessageTemplate {
  id               String               @id @default(cuid())
  key              String               @unique
  name             String
  channel          TemplateChannel      @default(WHATSAPP)
  kind             TemplateKind         @default(TEXT)
  deliveryMode     TemplateDeliveryMode @default(STANDARD)
  body             String
  mediaUrl         String?
  twilioContentSid String?
  language         String               @default("es-MX")
  isActive         Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model Conversation {
  id            String             @id @default(cuid())
  contactId     String
  flowId        String?
  courseId      String?
  selectedCourseId String?
  currentCourseModuleId String?
  currentCourseStepId String?
  currentStepId String?
  contextData   Json?
  status        ConversationStatus @default(OPEN)
  lastMessageAt DateTime           @default(now())
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  contact       Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  flow          BotFlow?           @relation(fields: [flowId], references: [id], onDelete: SetNull)
  course        Course?            @relation(fields: [courseId], references: [id], onDelete: SetNull)
  selectedCourse Course?           @relation("ConversationSelectedCourse", fields: [selectedCourseId], references: [id], onDelete: SetNull)
  currentCourseModule CourseModule? @relation(fields: [currentCourseModuleId], references: [id], onDelete: SetNull)
  currentCourseStep CourseStep?    @relation("ConversationCurrentCourseStep", fields: [currentCourseStepId], references: [id], onDelete: SetNull)
  currentStep   BotFlowStep?       @relation("ConversationCurrentStep", fields: [currentStepId], references: [id], onDelete: SetNull)
  messages      Message[]

  @@unique([contactId, flowId])
  @@unique([contactId, courseId])
  @@index([contactId])
  @@index([courseId])
  @@index([selectedCourseId])
}

model Message {
  id                 String           @id @default(cuid())
  contactId          String
  conversationId     String?
  direction          MessageDirection
  channel            MessageChannel   @default(WHATSAPP)
  provider           MessageProvider  @default(TWILIO)
  providerMessageSid String?          @unique
  body               String
  messageType        MessageType
  status             MessageStatus
  templateKey        String?
  errorCode          String?
  errorMessage       String?
  rawPayload         Json
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  contact            Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  conversation       Conversation?    @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([providerMessageSid])
  @@index([status])
}

model WebhookEvent {
  id          String        @id @default(cuid())
  source      WebhookSource
  eventId     String?
  payload     Json
  processedAt DateTime?
  status      String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([source, eventId])
}

model ApiKey {
  id        String   @id @default(cuid())
  name      String
  keyHash   String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
