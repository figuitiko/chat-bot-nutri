generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BotRuleMatchType {
  EXACT
  KEYWORD
  CONTAINS
  FALLBACK
}

enum TemplateChannel {
  WHATSAPP
}

enum TemplateKind {
  TEXT
  TWILIO_CONTENT_TEMPLATE
}

enum TemplateDeliveryMode {
  STANDARD
  MEDIA_FIRST
}

enum ConversationStatus {
  OPEN
  CLOSED
  ESCALATED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageChannel {
  WHATSAPP
}

enum MessageProvider {
  TWILIO
}

enum MessageType {
  TEXT
  TEMPLATE
  SYSTEM
}

enum MessageStatus {
  RECEIVED
  QUEUED
  SENT
  DELIVERED
  FAILED
  READ
}

enum WebhookSource {
  TWILIO_INBOUND
  TWILIO_STATUS
}

enum FlowStepInputType {
  CHOICE
  FREE_TEXT
}

enum FlowStepRenderMode {
  TEXT
  AUTO
  QUICK_REPLY
  LIST_PICKER
}

model Contact {
  id             String         @id @default(cuid())
  phone          String         @unique
  waId           String?
  name           String?
  profileName    String?
  locale         String         @default("es-MX")
  isOptedIn      Boolean        @default(true)
  lastInboundAt  DateTime?
  lastOutboundAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  conversations  Conversation[]
  messages       Message[]
}

model BotFlow {
  id                  String         @id @default(cuid())
  key                 String         @unique
  name                String
  description         String?
  isActive            Boolean        @default(true)
  entryStepKey        String?
  fallbackTemplateKey String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  conversations       Conversation[]
  rules               BotRule[]
  steps               BotFlowStep[]
}

model BotRule {
  id                  String           @id @default(cuid())
  flowId              String
  matchType           BotRuleMatchType
  pattern             String
  responseTemplateKey String?
  targetFlowKey       String?
  priority            Int              @default(100)
  isActive            Boolean          @default(true)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  flow                BotFlow          @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId, priority])
}

model BotFlowStep {
  id                  String                          @id @default(cuid())
  flowId              String
  key                 String
  name                String
  templateKey         String
  inputType           FlowStepInputType              @default(CHOICE)
  renderMode          FlowStepRenderMode             @default(TEXT)
  assessmentKey       String?
  correctAnswer       String?
  scoreWeight         Int?
  isAssessmentResult  Boolean                        @default(false)
  captureKey          String?
  isTerminal          Boolean                         @default(false)
  isActive            Boolean                         @default(true)
  createdAt           DateTime                        @default(now())
  updatedAt           DateTime                        @updatedAt
  flow                BotFlow                         @relation(fields: [flowId], references: [id], onDelete: Cascade)
  transitions         BotFlowTransition[]             @relation("TransitionSource")
  incomingTransitions BotFlowTransition[]             @relation("TransitionTarget")
  conversations       Conversation[]                  @relation("ConversationCurrentStep")

  @@unique([flowId, key])
  @@index([flowId])
}

model BotFlowTransition {
  id          String           @id @default(cuid())
  stepId       String
  nextStepId   String?
  matchType    BotRuleMatchType
  pattern      String
  outputValue  String?
  priority     Int              @default(100)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  step         BotFlowStep      @relation("TransitionSource", fields: [stepId], references: [id], onDelete: Cascade)
  nextStep     BotFlowStep?     @relation("TransitionTarget", fields: [nextStepId], references: [id], onDelete: SetNull)

  @@index([stepId, priority])
}

model MessageTemplate {
  id               String               @id @default(cuid())
  key              String               @unique
  name             String
  channel          TemplateChannel      @default(WHATSAPP)
  kind             TemplateKind         @default(TEXT)
  deliveryMode     TemplateDeliveryMode @default(STANDARD)
  body             String
  mediaUrl         String?
  twilioContentSid String?
  language         String               @default("es-MX")
  isActive         Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model Conversation {
  id            String             @id @default(cuid())
  contactId     String
  flowId        String?
  currentStepId String?
  contextData   Json?
  status        ConversationStatus @default(OPEN)
  lastMessageAt DateTime           @default(now())
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  contact       Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  flow          BotFlow?           @relation(fields: [flowId], references: [id], onDelete: SetNull)
  currentStep   BotFlowStep?       @relation("ConversationCurrentStep", fields: [currentStepId], references: [id], onDelete: SetNull)
  messages      Message[]

  @@unique([contactId, flowId])
  @@index([contactId])
}

model Message {
  id                 String           @id @default(cuid())
  contactId          String
  conversationId     String?
  direction          MessageDirection
  channel            MessageChannel   @default(WHATSAPP)
  provider           MessageProvider  @default(TWILIO)
  providerMessageSid String?          @unique
  body               String
  messageType        MessageType
  status             MessageStatus
  templateKey        String?
  errorCode          String?
  errorMessage       String?
  rawPayload         Json
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  contact            Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  conversation       Conversation?    @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([providerMessageSid])
  @@index([status])
}

model WebhookEvent {
  id          String        @id @default(cuid())
  source      WebhookSource
  eventId     String?
  payload     Json
  processedAt DateTime?
  status      String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([source, eventId])
}

model ApiKey {
  id        String   @id @default(cuid())
  name      String
  keyHash   String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
